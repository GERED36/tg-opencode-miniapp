{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt && cd tma && npm ci && npm run build && cd .."
  },
  "deploy": {
    "startCommand": "python -m hub.hub",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/api/ping"
  }
}
